@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Reflection

<div class="app-layout">
    <header class="app-header">
        <a href="@Nav.BaseUri" class="app-title">🍳 OpenCookbook</a>
    </header>
    <main class="app-main">
        @Body
    </main>
    <footer class="app-footer">
        <p>OpenCookbook — CC0 1.0 Universal (Public Domain) · @_appVersion</p>
        @if (_isDark.HasValue)
        {
            <button class="theme-toggle" @onclick="ToggleThemeAsync" aria-label="@(_isDark.Value ? "Switch to light mode" : "Switch to dark mode")">
                @(_isDark.Value ? "☀️ Light mode" : "🌙 Dark mode")
            </button>
        }
    </footer>
</div>

@code {
    private string _appVersion = "dev";
    private bool? _isDark;

    protected override void OnInitialized()
    {
        var infoVersion = typeof(App).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()
            ?.InformationalVersion;

        if (string.IsNullOrWhiteSpace(infoVersion))
        {
            _appVersion = "dev";
            return;
        }

        var parts = infoVersion.Split('+', 2);
        var version = parts[0];
        var commitHash = parts.Length > 1 && !string.IsNullOrEmpty(parts[1]) ? parts[1] : null;

        // Show version + short commit hash for build verification
        _appVersion = commitHash is not null
            ? $"v{version} ({commitHash[..Math.Min(7, commitHash.Length)]})"
            : $"v{version}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeInterop.getTheme");
            _isDark = theme == "dark";
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync()
    {
        var desiredIsDark = !(_isDark ?? false);
        var desiredTheme = desiredIsDark ? "dark" : "light";

        try
        {
            await JS.InvokeVoidAsync("themeInterop.setTheme", desiredTheme);
            _isDark = desiredIsDark;
        }
        catch
        {
            // If the JS interop call fails, leave _isDark unchanged so the UI
            // remains consistent with the actual applied theme.
        }
    }
}

