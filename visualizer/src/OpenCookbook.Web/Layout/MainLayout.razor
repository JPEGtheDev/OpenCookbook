@inherits LayoutComponentBase
@inject NavigationManager Nav
@using System.Reflection

<div class="app-layout">
    <header class="app-header">
        <a href="@Nav.BaseUri" class="app-title">🍳 OpenCookbook</a>
    </header>
    <main class="app-main">
        @Body
    </main>
    <footer class="app-footer">
        <p>OpenCookbook — CC0 1.0 Universal (Public Domain) · @_appVersion</p>
    </footer>
</div>

@code {
    private string _appVersion = "dev";

    protected override void OnInitialized()
    {
        var infoVersion = typeof(App).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()
            ?.InformationalVersion;

        var cleanVersion = infoVersion?.Split('+')[0];
        _appVersion = string.IsNullOrWhiteSpace(cleanVersion) ? "dev" : $"v{cleanVersion}";
    }
}

