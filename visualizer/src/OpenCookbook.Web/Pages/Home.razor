@page "/"
@inject RecipeService RecipeService
@inject NavigationManager Nav

<PageTitle>OpenCookbook</PageTitle>

<div class="home-page">
    <h1>Recipes</h1>

    @if (_loading)
    {
        <p class="loading-message">Loading recipes…</p>
    }
    else if (_error is not null)
    {
        <p class="error-message">@_error</p>
    }
    else if (_loaded)
    {
        <div class="search-bar">
            <label for="recipe-search" class="visually-hidden">Search recipes</label>
            <input id="recipe-search"
                   type="search"
                   class="search-input"
                   placeholder="Search by name, ingredient or tag…"
                   aria-label="Search recipes by name, ingredient or tag"
                   value="@_searchQuery"
                   @oninput="OnSearchInput" />
        </div>

        @if (_filteredRecipes.Count == 0)
        {
            <p class="no-recipes-message">No recipes found for "<strong>@_searchQuery</strong>".</p>
        }
        else
        {
            <div class="recipe-grid">
                @foreach (var recipe in _filteredRecipes)
                {
                    <a class="recipe-card" href="recipe/@Uri.EscapeDataString(recipe.Path)">
                        <h2 class="recipe-card-title">@recipe.Name</h2>
                        <p class="recipe-card-description">@recipe.Description</p>
                        <StatusBadge Status="@recipe.Status" />
                    </a>
                }
            </div>
        }
    }

    <div class="url-import-section">
        <h2 class="url-import-heading">Open Recipe by URL</h2>
        <p class="url-import-hint">Paste a recipe URL (e.g. from a shared link) to open it directly.</p>
        <div class="url-import-form">
            <label for="recipe-url" class="visually-hidden">Recipe URL</label>
            <input id="recipe-url"
                   type="url"
                   class="url-import-input"
                   placeholder="https://jpegthedev.github.io/OpenCookbook/recipe/Chicken.yaml"
                   aria-label="Recipe URL"
                   @bind="_urlInput"
                   @bind:event="oninput"
                   @onkeydown="OnUrlKeyDown" />
            <button class="export-btn export-btn-primary url-import-btn" @onclick="OpenByUrl">Open</button>
        </div>
        @if (_urlError is not null)
        {
            <p class="url-import-error" role="alert">@_urlError</p>
        }
    </div>
</div>

@code {
    private bool _loaded;
    private List<RecipeIndex> _filteredRecipes = [];
    private bool _loading = true;
    private string? _error;
    private string _searchQuery = string.Empty;

    private string _urlInput = string.Empty;
    private string? _urlError;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        await ApplyFilterAsync();
    }

    private async Task ApplyFilterAsync()
    {
        _filteredRecipes = (await RecipeService.SearchRecipesAsync(_searchQuery)).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await ApplyFilterAsync();
            _loaded = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load recipes: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnUrlKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await OpenByUrl();
    }

    private Task OpenByUrl()
    {
        _urlError = null;
        var input = _urlInput.Trim();

        if (string.IsNullOrEmpty(input))
        {
            _urlError = "Please enter a recipe URL.";
            return Task.CompletedTask;
        }

        // Same-site URL: extract local path and navigate via the existing recipe route
        if (RecipeService.TryExtractLocalPath(input, Nav.BaseUri, out var localPath))
        {
            Nav.NavigateTo($"recipe/{Uri.EscapeDataString(localPath)}");
            return Task.CompletedTask;
        }

        // External HTTPS .yaml URL: pass the full URL as the route parameter
        if (Uri.TryCreate(input, UriKind.Absolute, out var uri)
            && string.Equals(uri.Scheme, "https", StringComparison.OrdinalIgnoreCase)
            && input.EndsWith(".yaml", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo($"recipe/{Uri.EscapeDataString(input)}");
            return Task.CompletedTask;
        }

        _urlError = "Enter a valid HTTPS URL ending in .yaml (e.g. https://example.com/recipe.yaml).";
        return Task.CompletedTask;
    }
}
