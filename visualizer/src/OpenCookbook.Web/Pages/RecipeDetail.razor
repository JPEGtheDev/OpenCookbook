@page "/recipe/{**Path}"
@inject RecipeService RecipeService
@inject RecipeComposer RecipeComposer
@inject NutritionCalculator NutritionCalculator
@inject FitnessExportService ExportService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@(_recipe?.Name ?? "Recipe") — OpenCookbook</PageTitle>

@if (_loading)
{
    <p class="loading-message">Loading recipe…</p>
}
else if (_error is not null)
{
    <div class="error-message">
        <p>@_error</p>
        <a href="@Nav.BaseUri">← Back to recipes</a>
    </div>
}
else if (_recipe is not null)
{
    <article class="recipe-detail">
        <header class="recipe-header">
            <h1>@_recipe.Name</h1>
            <div class="recipe-meta">
                <span class="recipe-author">@_recipe.Author</span>
                <span class="recipe-version">v@(_recipe.Version)</span>
                <StatusBadge Status="@_recipe.Status" />
            </div>
            <p class="recipe-description">@_recipe.Description</p>
        </header>

        <div class="recipe-body">
            <aside class="recipe-sidebar">
                <IngredientList Groups="@_recipe.Ingredients"
                               BaseGroups="@_composedRecipe?.Ingredients"
                               RecipePath="@_decodedPath"
                               Yields="@_recipe.Yields"
                               Multiplier="@_multiplier"
                               MultiplierChanged="@OnMultiplierChanged"
                               AlternateSelections="@_alternateSelections"
                               AlternateChanged="@OnAlternateChanged" />

                @if (_recipe.Utensils is { Count: > 0 })
                {
                    <section class="utensils-section">
                        <h2>Utensils</h2>
                        @foreach (var group in _recipe.Utensils)
                        {
                            @if (group.Heading is not null)
                            {
                                <h3 class="group-heading">@group.Heading</h3>
                            }
                            <ul class="utensil-list">
                                @foreach (var item in group.Items)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        }
                    </section>
                }

                <NutritionPanel Nutrition="@_nutrition" Multiplier="@_multiplier" />
            </aside>

            <div class="recipe-instructions">
                <InstructionList Sections="@_recipe.Instructions" />
            </div>
        </div>

        <footer class="recipe-footer">
            @if (_recipe.Related is { Count: > 0 })
            {
                <section class="related-section">
                    <h2>Related Recipes</h2>
                    <ul class="related-list">
                        @foreach (var related in _recipe.Related)
                        {
                            <li>
                                <a href="@GetRelatedRecipeUrl(related.Path)">@related.Label</a>
                            </li>
                        }
                    </ul>
                </section>
            }

            @if (_recipe.Status != RecipeStatus.Stable && _recipe.Notes is { Count: > 0 })
            {
                <section class="notes-section">
                    <h2>Notes</h2>
                    <ul class="notes-list">
                        @foreach (var note in _recipe.Notes)
                        {
                            <li>@note</li>
                        }
                    </ul>
                </section>
            }
        </footer>

        <a href="@Nav.BaseUri" class="back-link">← Back to recipes</a>

        <section class="export-section">
            <h2>Export for Fitness Tracking</h2>
            <div class="export-buttons">
                <button class="export-btn export-btn-primary" @onclick="ShowExportModal">Export Ingredients</button>
            </div>
            <div class="share-url-section">
                <p class="share-url-hint">Share this recipe with any app that can import from a website URL:</p>
                <div class="share-url-row">
                    <code class="share-url-code">@ShareUrl</code>
                    <button class="export-btn export-btn-copy" @onclick="CopyShareUrl">
                        @(_shareUrlCopied ? "✓ Copied!" : "Share this link")
                    </button>
                </div>
            </div>
        </section>
    </article>

    <ExportModal Title="Export Ingredients"
                 Hint="Paste into your fitness app's recipe importer. Each ingredient is listed as: quantity unit name."
                 Text="@_exportText"
                 IsOpen="@_showExportModal"
                 OnClose="@(() => _showExportModal = false)" />
}

@code {
    [Parameter]
    public string Path { get; set; } = string.Empty;

    private Recipe? _composedRecipe;
    private Recipe? _recipe;
    private RecipeNutrition? _nutrition;
    private bool _loading = true;
    private string? _error;
    private string? _decodedPath;
    private double _multiplier = 1.0;
    private Dictionary<AlternateSelector.IngredientKey, int> _alternateSelections = new();
    private int _recalcVersion;

    private bool _showExportModal;
    private string _exportText = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _composedRecipe = null;
        _recipe = null;
        _nutrition = null;
        _decodedPath = null;
        _multiplier = 1.0;
        _alternateSelections = new();
        _showExportModal = false;
        _exportText = string.Empty;

        try
        {
            _decodedPath = Uri.UnescapeDataString(Path);

            // Redirect legacy .yaml URLs to the canonical URL (no extension).
            if (_decodedPath.EndsWith(".yaml", StringComparison.OrdinalIgnoreCase))
            {
                var canonical = _decodedPath[..^5];
                Nav.NavigateTo($"{Nav.BaseUri}recipe/{RecipeUrlHelper.EscapeRecipePath(canonical)}", replace: true);
                _loading = false;
                return;
            }

            _recipe = await RecipeService.GetRecipeByPathAsync(_decodedPath);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load recipe: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        if (_recipe is not null && _decodedPath is not null)
        {
            try
            {
                var composed = await RecipeComposer.ComposeAsync(_recipe, _decodedPath);
                _composedRecipe = composed;
                _recipe = composed;
            }
            catch
            {
                // Composition is best-effort — show the raw recipe if it fails.
                // _composedRecipe points to the same instance as _recipe so that
                // AlternateSelector.ApplySelections still has a base to work from.
                _composedRecipe = _recipe;
            }
        }

        await RecalculateNutritionAndExport();
    }

    private async Task RecalculateNutritionAndExport(int? requiredVersion = null)
    {
        _nutrition = null;

        if (_recipe is not null && _decodedPath is not null)
        {
            try
            {
                var nutrition = await NutritionCalculator.CalculateAsync(_recipe, basePath: GetRecipeDirectory(_decodedPath));
                if (requiredVersion is null || requiredVersion == _recalcVersion)
                    _nutrition = nutrition;
            }
            catch
            {
                // Nutrition is optional — don't block the page if calculation fails
            }
        }

        if (_recipe is not null && _decodedPath is not null)
        {
            var exportText = await ExportService.GenerateExportAsync(_recipe, basePath: GetRecipeDirectory(_decodedPath));
            if (requiredVersion is null || requiredVersion == _recalcVersion)
                _exportText = exportText;
        }
    }

    private void ShowExportModal() => _showExportModal = true;

    private void OnMultiplierChanged(double multiplier) => _multiplier = multiplier;

    private async Task OnAlternateChanged((AlternateSelector.IngredientKey Key, int AlternateIndex) selection)
    {
        if (_composedRecipe is null) return;

        if (selection.AlternateIndex < 0)
            _alternateSelections.Remove(selection.Key);
        else
            _alternateSelections[selection.Key] = selection.AlternateIndex;

        _recipe = AlternateSelector.ApplySelections(_composedRecipe, _alternateSelections);
        var version = ++_recalcVersion;
        await RecalculateNutritionAndExport(version);
    }

    private string GetRelatedRecipeUrl(string relativePath)
    {
        var decodedPath = _decodedPath ?? Uri.UnescapeDataString(Path);

        // Guard against malicious route parameter values
        if (decodedPath.Contains("..") || decodedPath.StartsWith('/') || decodedPath.StartsWith('\\'))
            return Nav.BaseUri;

        var currentDir = decodedPath.Contains('/')
            ? decodedPath[..decodedPath.LastIndexOf('/')]
            : "";

        var resolved = relativePath.StartsWith("./")
            ? relativePath[2..]
            : relativePath;

        var fullPath = string.IsNullOrEmpty(currentDir)
            ? resolved
            : $"{currentDir}/{resolved}";

        return $"{Nav.BaseUri}recipe/{RecipeUrlHelper.EscapeRecipePath(fullPath)}";
    }

    private static string? GetRecipeDirectory(string path)
    {
        var lastSlash = path.LastIndexOf('/');
        return lastSlash > 0 ? path[..lastSlash] : null;
    }

    private string ShareUrl
    {
        get
        {
            if (_decodedPath is null) return string.Empty;
            // _decodedPath is already the canonical slug (no .yaml) after the redirect guard above,
            // but strip the extension defensively in case it's still present.
            var slug = _decodedPath.EndsWith(".yaml", StringComparison.OrdinalIgnoreCase)
                ? _decodedPath[..^5]
                : _decodedPath;
            return $"{Nav.BaseUri}recipe/{RecipeUrlHelper.EscapeRecipePath(slug)}";
        }
    }

    private bool _shareUrlCopied;
    private CancellationTokenSource? _shareUrlCts;

    private async Task CopyShareUrl()
    {
        _shareUrlCts?.Cancel();
        _shareUrlCts?.Dispose();
        _shareUrlCts = new CancellationTokenSource();
        var cts = _shareUrlCts;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", ShareUrl);
            _shareUrlCopied = true;
            StateHasChanged();
            await Task.Delay(2000, cts.Token);
            _shareUrlCopied = false;
            StateHasChanged();
        }
        catch (OperationCanceledException) { }
        catch
        {
            // Clipboard write failed — leave _shareUrlCopied false so the button label stays unchanged
        }
    }

    public void Dispose()
    {
        _shareUrlCts?.Cancel();
        _shareUrlCts?.Dispose();
    }
}
