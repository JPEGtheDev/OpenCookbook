@using OpenCookbook.Domain.Entities
@using OpenCookbook.Application.Services

@if (_loading)
{
    <section class="nutrition-section">
        <h2>Nutrition</h2>
        <p class="nutrition-loading">Calculating nutrition…</p>
    </section>
}
else if (Nutrition is not null)
{
    var total = Multiplier != 1.0
        ? RecipeScaler.ScaleNutrients(Nutrition.TotalNutrients, Multiplier)
        : Nutrition.TotalNutrients;

    <section class="nutrition-section">
        <h2>Nutrition</h2>

        @if (!Nutrition.IsComplete)
        {
            <p class="nutrition-warning">⚠️ Nutrition data incomplete — some ingredients are missing data.</p>
        }

        <div class="nutrition-summary">
            <div class="nutrition-card">
                <h3>Per Recipe @(Multiplier != 1.0 ? $"({FormatMultiplier(Multiplier)})" : "")</h3>
                <div class="nutrition-grid">
                    <div class="nutrition-item nutrition-calories">
                        <span class="nutrition-value">@FormatValue(total.CaloriesKcal)</span>
                        <span class="nutrition-label">Calories</span>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">@FormatValue(total.ProteinG)g</span>
                        <span class="nutrition-label">Protein</span>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">@FormatValue(total.FatG)g</span>
                        <span class="nutrition-label">Fat</span>
                    </div>
                    <div class="nutrition-item">
                        <span class="nutrition-value">@FormatValue(total.CarbsG)g</span>
                        <span class="nutrition-label">Carbs</span>
                    </div>
                </div>
            </div>

            @if (Nutrition.PerUnitNutrients is not null
                && Nutrition.YieldsQuantity is not null
                && Nutrition.YieldsUnit is not null
                && !NonPluralizableUnits.Contains(Nutrition.YieldsUnit)
                && !(string.Equals(Nutrition.YieldsUnit, "serving", StringComparison.OrdinalIgnoreCase)
                     && Nutrition.ServingSizeQuantity is not null))
            {
                var scaledYieldsQty = Math.Round(Nutrition.YieldsQuantity.Value * Multiplier, 1);
                <div class="nutrition-card">
                    <h3>Per @Capitalize(Nutrition.YieldsUnit) <span class="nutrition-servings">(@FormatValue(scaledYieldsQty) total)</span></h3>
                    <div class="nutrition-grid">
                        <div class="nutrition-item nutrition-calories">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerUnitNutrients!.CaloriesKcal)</span>
                            <span class="nutrition-label">Calories</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerUnitNutrients.ProteinG)g</span>
                            <span class="nutrition-label">Protein</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerUnitNutrients.FatG)g</span>
                            <span class="nutrition-label">Fat</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerUnitNutrients.CarbsG)g</span>
                            <span class="nutrition-label">Carbs</span>
                        </div>
                    </div>
                </div>
            }

            @if (Nutrition.PerServingNutrients is not null && Nutrition.ServingSizeQuantity is not null && Nutrition.ServingSizeQuantity > 1)
            {
                <div class="nutrition-card">
                    <h3>Per Serving <span class="nutrition-servings">(@Nutrition.ServingSizeQuantity @Pluralize(Nutrition.ServingSizeUnit, Nutrition.ServingSizeQuantity))</span></h3>
                    <div class="nutrition-grid">
                        <div class="nutrition-item nutrition-calories">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.CaloriesKcal)</span>
                            <span class="nutrition-label">Calories</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.ProteinG)g</span>
                            <span class="nutrition-label">Protein</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.FatG)g</span>
                            <span class="nutrition-label">Fat</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.CarbsG)g</span>
                            <span class="nutrition-label">Carbs</span>
                        </div>
                    </div>
                </div>
            }
            else if (Nutrition.PerServingNutrients is not null && Nutrition.Servings > 1)
            {
                <div class="nutrition-card">
                    <h3>Per Serving <span class="nutrition-servings">(@Nutrition.Servings servings)</span></h3>
                    <div class="nutrition-grid">
                        <div class="nutrition-item nutrition-calories">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.CaloriesKcal)</span>
                            <span class="nutrition-label">Calories</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.ProteinG)g</span>
                            <span class="nutrition-label">Protein</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.FatG)g</span>
                            <span class="nutrition-label">Fat</span>
                        </div>
                        <div class="nutrition-item">
                            <span class="nutrition-value">@FormatValue(Nutrition.PerServingNutrients.CarbsG)g</span>
                            <span class="nutrition-label">Carbs</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Nutrition.MissingIngredients.Count > 0)
        {
            <details class="nutrition-missing">
                <summary>@Nutrition.MissingIngredients.Count ingredient(s) missing nutrition data</summary>
                <ul>
                    @foreach (var name in Nutrition.MissingIngredients)
                    {
                        <li>@name</li>
                    }
                </ul>
            </details>
        }
    </section>
}

@code {
    [Parameter]
    public RecipeNutrition? Nutrition { get; set; }

    [Parameter]
    public double Multiplier { get; set; } = 1.0;

    private bool _loading;

    protected override void OnParametersSet()
    {
        _loading = Nutrition is null;
    }

    private static string FormatValue(double value)
    {
        return value == Math.Floor(value) ? value.ToString("F0") : value.ToString("F1");
    }

    private static string FormatMultiplier(double m)
    {
        return m == Math.Floor(m) ? $"{m:F0}×" : $"{m:G3}×";
    }

    private static string Capitalize(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Length == 1) return char.ToUpperInvariant(value[0]).ToString();
        return char.ToUpperInvariant(value[0]) + value[1..];
    }

    private static readonly HashSet<string> NonPluralizableUnits =
        new(StringComparer.OrdinalIgnoreCase) { "g", "ml", "kg", "l", "oz", "lb", "lbs" };

    private static string Pluralize(string? unit, int? quantity)
    {
        if (string.IsNullOrEmpty(unit)) return string.Empty;
        if (quantity == 1) return unit;
        if (NonPluralizableUnits.Contains(unit)) return unit;
        return unit + "s";
    }
}
