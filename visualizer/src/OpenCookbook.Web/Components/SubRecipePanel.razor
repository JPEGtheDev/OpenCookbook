@using OpenCookbook.Application.Interfaces
@using OpenCookbook.Domain.Entities
@inject IRecipeRepository RecipeRepository

@if (_subRecipe is not null)
{
    <details class="sub-recipe-details">
        <summary class="sub-recipe-toggle">@IngredientName</summary>
        <div class="sub-recipe-content">
            @foreach (var group in _subRecipe.Ingredients)
            {
                @if (group.Heading is not null)
                {
                    <p class="sub-recipe-group-heading">@group.Heading</p>
                }
                <ul class="sub-recipe-ingredient-list">
                    @foreach (var item in group.Items)
                    {
                        <li>
                            <span class="sub-recipe-qty">@FormatQuantity(item.Quantity) @item.Unit</span>
                            <span>@item.Name</span>
                            @if (item.VolumeAlt is not null)
                            {
                                <span class="ingredient-vol-alt">(≈ @item.VolumeAlt)</span>
                            }
                        </li>
                    }
                </ul>
            }
            @if (_subRecipe.Instructions.Count > 0)
            {
                @foreach (var instrSection in _subRecipe.Instructions)
                {
                    @if (instrSection.Heading is not null)
                    {
                        <p class="sub-recipe-section-heading">@instrSection.Heading</p>
                    }
                    <ol class="sub-recipe-step-list">
                        @foreach (var step in instrSection.Steps)
                        {
                            <li>@step.Text</li>
                        }
                    </ol>
                }
            }
        </div>
    </details>
}
else if (_loadFailed && FallbackUrl is not null)
{
    <a href="@FallbackUrl">@IngredientName</a>
}
else
{
    @IngredientName
}

@code {
    [Parameter, EditorRequired]
    public string DocLink { get; set; } = "";

    [Parameter]
    public string? RecipePath { get; set; }

    [Parameter]
    public string? IngredientName { get; set; }

    [Parameter]
    public string? FallbackUrl { get; set; }

    private Recipe? _subRecipe;
    private bool _loadFailed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resolvedPath = ResolveDocLink(RecipePath, DocLink);
            _subRecipe = await RecipeRepository.GetRecipeAsync(resolvedPath);
        }
        catch
        {
            _loadFailed = true;
        }
    }

    public static string ResolveDocLink(string? recipePath, string docLink)
    {
        var currentDir = "";
        if (recipePath is not null && recipePath.Contains('/'))
            currentDir = recipePath[..recipePath.LastIndexOf('/')];

        var linkPath = docLink.StartsWith("./", StringComparison.Ordinal) ? docLink[2..] : docLink;

        return string.IsNullOrEmpty(currentDir) ? linkPath : $"{currentDir}/{linkPath}";
    }

    private static string FormatQuantity(double qty)
    {
        if (qty == Math.Floor(qty))
            return qty.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);

        return Math.Round(qty, 1) == qty
            ? qty.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
            : qty.ToString("G4", System.Globalization.CultureInfo.InvariantCulture);
    }
}
