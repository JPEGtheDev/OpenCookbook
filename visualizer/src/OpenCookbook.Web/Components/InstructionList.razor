<section class="instructions-container">
    <h2>Instructions</h2>

    @{ var sequenceSections = Sections.Where(s => s.Type == SectionType.Sequence).ToList(); }
    @{ var branchSections = Sections.Where(s => s.Type == SectionType.Branch).ToList(); }
    @{ var branchGroups = branchSections.GroupBy(s => s.BranchGroup ?? s.Heading ?? "Options").ToList(); }

    @* Render sequence sections *@
    @foreach (var seq in sequenceSections)
    {
        <div class="instruction-section @(seq.Optional ? "instruction-optional" : "")">
            @if (seq.Heading is not null)
            {
                <h3 class="section-heading">
                    @seq.Heading
                    @if (seq.Optional)
                    {
                        <span class="optional-label">(optional)</span>
                    }
                </h3>
            }

            <ol class="step-list">
                @foreach (var step in seq.Steps)
                {
                    <li class="step-item">
                        <span class="step-text">@step.Text</span>
                        @if (step.Notes is { Count: > 0 })
                        {
                            <div class="step-notes">
                                @foreach (var note in step.Notes)
                                {
                                    <p class="step-note">💡 @note</p>
                                }
                            </div>
                        }
                    </li>
                }
            </ol>
        </div>
    }

    @* Render branch sections as tabbed groups *@
    @foreach (var group in branchGroups)
    {
        var groupKey = group.Key;
        var options = group.ToList();

        <div class="branch-group">
            <h3 class="section-heading">@groupKey</h3>
            <div class="branch-tabs" role="tablist">
                @foreach (var option in options)
                {
                    var label = option.Heading ?? "Option";
                    var isActive = GetActiveTab(groupKey) == label;

                    <button class="branch-tab @(isActive ? "branch-tab-active" : "")"
                            role="tab"
                            aria-selected="@isActive"
                            @onclick="() => SetActiveTab(groupKey, label)">
                        @label
                        @if (option.Optional)
                        {
                            <span class="optional-label">(optional)</span>
                        }
                    </button>
                }
            </div>

            @foreach (var option in options)
            {
                var label = option.Heading ?? "Option";
                var isActive = GetActiveTab(groupKey) == label;

                @if (isActive)
                {
                    <div class="branch-panel" role="tabpanel">
                        <ol class="step-list">
                            @foreach (var step in option.Steps)
                            {
                                <li class="step-item">
                                    <span class="step-text">@step.Text</span>
                                    @if (step.Notes is { Count: > 0 })
                                    {
                                        <div class="step-notes">
                                            @foreach (var note in step.Notes)
                                            {
                                                <p class="step-note">💡 @note</p>
                                            }
                                        </div>
                                    }
                                </li>
                            }
                        </ol>
                    </div>
                }
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public List<Section> Sections { get; set; } = [];

    private readonly Dictionary<string, string> _activeTabs = new();

    private string GetActiveTab(string groupKey)
    {
        if (_activeTabs.TryGetValue(groupKey, out var tab))
            return tab;

        // Default to first tab in group
        var first = Sections
            .Where(s => s.Type == SectionType.Branch && (s.BranchGroup ?? s.Heading ?? "Options") == groupKey)
            .Select(s => s.Heading ?? "Option")
            .FirstOrDefault() ?? "Option";

        _activeTabs[groupKey] = first;
        return first;
    }

    private void SetActiveTab(string groupKey, string label)
    {
        _activeTabs[groupKey] = label;
    }
}
