<section class="instructions-container">
    <h2>Instructions</h2>

    @foreach (var item in _renderItems)
    {
        if (item.IsSequence)
        {
            var seq = item.Section!;
            <div class="instruction-section @(seq.Optional && seq.Type != SectionType.Storage ? "instruction-optional" : "")">
                @if (seq.Heading is not null)
                {
                    <h3 class="section-heading">
                        @seq.Heading
                        @if (seq.Optional)
                        {
                            <span class="optional-label">(optional)</span>
                        }
                    </h3>
                }

                <ol class="step-list">
                    @foreach (var step in seq.Steps)
                    {
                        <li class="step-item">
                            <span class="step-text">@step.Text</span>
                            @if (step.Notes is { Count: > 0 })
                            {
                                <div class="step-notes">
                                    @foreach (var note in step.Notes)
                                    {
                                        <p class="step-note">💡 @note</p>
                                    }
                                </div>
                            }
                        </li>
                    }
                </ol>
            </div>
        }
        else
        {
            var groupKey = item.BranchGroupKey!;
            var options = item.BranchOptions!;

            <div class="branch-group">
                <div class="branch-tabs" role="tablist">
                    @foreach (var option in options)
                    {
                        var label = option.Heading ?? "Option";
                        var isActive = GetActiveTab(groupKey) == label;
                        var tabId = $"tab-{groupKey}-{label}".Replace(" ", "-").ToLowerInvariant();
                        var panelId = $"panel-{groupKey}-{label}".Replace(" ", "-").ToLowerInvariant();

                        <button class="branch-tab @(isActive ? "branch-tab-active" : "")"
                                id="@tabId"
                                role="tab"
                                aria-selected="@isActive"
                                aria-controls="@panelId"
                                @onclick="() => SetActiveTab(groupKey, label)">
                            @label
                            @if (option.Optional)
                            {
                                <span class="optional-label">(optional)</span>
                            }
                        </button>
                    }
                </div>

                @foreach (var option in options)
                {
                    var label = option.Heading ?? "Option";
                    var isActive = GetActiveTab(groupKey) == label;
                    var tabId = $"tab-{groupKey}-{label}".Replace(" ", "-").ToLowerInvariant();
                    var panelId = $"panel-{groupKey}-{label}".Replace(" ", "-").ToLowerInvariant();

                    @if (isActive)
                    {
                        <div class="branch-panel" id="@panelId" role="tabpanel" aria-labelledby="@tabId">
                            <ol class="step-list">
                                @foreach (var step in option.Steps)
                                {
                                    <li class="step-item">
                                        <span class="step-text">@step.Text</span>
                                        @if (step.Notes is { Count: > 0 })
                                        {
                                            <div class="step-notes">
                                                @foreach (var note in step.Notes)
                                                {
                                                    <p class="step-note">💡 @note</p>
                                                }
                                            </div>
                                        }
                                    </li>
                                }
                            </ol>
                        </div>
                    }
                }
            </div>
        }
    }
</section>

@code {
    [Parameter, EditorRequired]
    public List<Section> Sections { get; set; } = [];

    /// <summary>
    /// When <c>true</c>, sections with <see cref="SectionType.Storage"/>
    /// are excluded from rendering. Used on composed recipe pages where sub-recipe
    /// storage instructions are irrelevant.
    /// </summary>
    [Parameter]
    public bool SuppressStorage { get; set; }

    private List<RenderItem> _renderItems = [];
    private readonly Dictionary<string, string> _activeTabs = new();

    protected override void OnParametersSet()
    {
        _renderItems = BuildRenderItems(Sections, SuppressStorage);
    }

    private static List<RenderItem> BuildRenderItems(List<Section> sections, bool suppressStorage)
    {
        var items = new List<RenderItem>();
        var renderedBranchGroups = new HashSet<string>();

        foreach (var section in sections)
        {
            if (suppressStorage && section.Type == SectionType.Storage)
                continue;

            if (section.Type == SectionType.Sequence || section.Type == SectionType.Storage)
            {
                items.Add(new RenderItem { IsSequence = true, Section = section });
            }
            else
            {
                var groupKey = section.BranchGroup ?? section.Heading ?? "Options";
                if (renderedBranchGroups.Add(groupKey))
                {
                    var options = sections
                        .Where(s => s.Type == SectionType.Branch
                            && (s.BranchGroup ?? s.Heading ?? "Options") == groupKey)
                        .ToList();
                    items.Add(new RenderItem { IsSequence = false, BranchGroupKey = groupKey, BranchOptions = options });
                }
            }
        }

        return items;
    }

    private string GetActiveTab(string groupKey)
    {
        if (_activeTabs.TryGetValue(groupKey, out var tab))
            return tab;

        var first = Sections
            .Where(s => s.Type == SectionType.Branch && (s.BranchGroup ?? s.Heading ?? "Options") == groupKey)
            .Select(s => s.Heading ?? "Option")
            .FirstOrDefault() ?? "Option";

        _activeTabs[groupKey] = first;
        return first;
    }

    private void SetActiveTab(string groupKey, string label)
    {
        _activeTabs[groupKey] = label;
    }

    private sealed class RenderItem
    {
        public bool IsSequence { get; init; }
        public Section? Section { get; init; }
        public string? BranchGroupKey { get; init; }
        public List<Section>? BranchOptions { get; init; }
    }
}
